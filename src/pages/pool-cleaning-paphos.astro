---
import Navbar from '../components/Navbar.astro';
import { ClientRouter } from 'astro:transitions';
import { MapPin, Droplets, Phone } from '@lucide/astro';

const siteTitle = "Pool Cleaning Paphos | Swimming Pool Maintenance Paphos Cyprus";
const siteDescription = "Professional pool cleaning and maintenance in Paphos, Cyprus. Reliable weekly service for villas, holiday rentals, and complexes across Paphos and the surrounding area.";
const siteUrl = "https://poolcleaningcyprus.com";
const siteName = "Pool Cleaning Cyprus";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{siteTitle}</title>
		<meta name="description" content={siteDescription} />
		<meta name="keywords" content="pool cleaning paphos, swimming pool maintenance paphos, pool service paphos cyprus, pool technician paphos" />
		<meta name="author" content={siteName} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={`${siteUrl}/pool-cleaning-paphos`} />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={siteDescription} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />

		<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Pool Cleaning Cyprus - Paphos",
			"description": "Professional pool cleaning and maintenance services in Paphos, Cyprus.",
			"url": "https://poolcleaningcyprus.com/pool-cleaning-paphos",
			"areaServed": { "@type": "City", "name": "Paphos" },
			"address": { "@type": "PostalAddress", "addressLocality": "Paphos", "addressCountry": "CY" }
		}
		</script>

		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }
			html { scroll-behavior: smooth; }
			body {
				font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
				background: #f0f9ff;
				color: #0c1a2e;
				min-height: 100vh;
				overflow-x: hidden;
			}
			:global(html.dark) body { background: #071829; color: #e0f2fe; }

			.page-wrapper {
				max-width: 720px;
				margin: 0 auto;
				padding: 140px 24px 80px;
			}

			.location-badge {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				font-size: 0.8rem;
				font-weight: 600;
				color: #0ea5e9;
				background: rgba(14,165,233,0.08);
				border: 1px solid rgba(14,165,233,0.2);
				padding: 6px 14px;
				border-radius: 20px;
				margin-bottom: 20px;
			}
			:global(html.dark) .location-badge {
				color: #38bdf8;
				background: rgba(56,189,248,0.08);
				border-color: rgba(56,189,248,0.2);
			}

			h1 {
				font-size: clamp(2rem, 5vw, 3rem);
				font-weight: 700;
				letter-spacing: -0.03em;
				color: #0c1a2e;
				margin-bottom: 20px;
			}
			:global(html.dark) h1 { color: #e0f2fe; }

			.body-text {
				font-size: 1rem;
				line-height: 1.75;
				color: #475569;
				margin-bottom: 20px;
			}
			:global(html.dark) .body-text { color: #94a3b8; }

			h2 {
				font-size: 1.3rem;
				font-weight: 700;
				letter-spacing: -0.02em;
				color: #0c1a2e;
				margin: 40px 0 16px;
			}
			:global(html.dark) h2 { color: #e0f2fe; }

			.services-list {
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 10px;
				margin-bottom: 32px;
			}

			.services-list li {
				display: flex;
				align-items: flex-start;
				gap: 10px;
				font-size: 0.9rem;
				color: #475569;
				padding: 14px 18px;
				background: rgba(255,255,255,0.7);
				border: 1px solid rgba(14,165,233,0.1);
				border-radius: 10px;
			}
			:global(html.dark) .services-list li {
				color: #94a3b8;
				background: rgba(14,42,71,0.4);
				border-color: rgba(56,189,248,0.1);
			}

			.services-list li :global(svg) {
				color: #0ea5e9;
				flex-shrink: 0;
				margin-top: 1px;
			}
			:global(html.dark) .services-list li :global(svg) { color: #38bdf8; }

			.cta-button {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 14px 28px;
				border-radius: 12px;
				font-size: 0.95rem;
				font-weight: 600;
				text-decoration: none;
				background: #0ea5e9;
				color: #fff;
				box-shadow: 0 4px 20px rgba(14,165,233,0.35);
				transition: all 0.2s ease;
				margin-top: 16px;
			}
			.cta-button:hover {
				background: #0284c7;
				transform: translateY(-1px);
			}

			footer {
				text-align: center;
				padding: 32px 24px;
				font-size: 0.82rem;
				color: #94a3b8;
				border-top: 1px solid rgba(14,165,233,0.1);
				margin-top: 40px;
			}
			:global(html.dark) footer { border-color: rgba(56,189,248,0.08); }
		</style>
	</head>
	<body>
		<Navbar />
		<div class="page-wrapper">
			<div class="location-badge">
				<MapPin size={14} />
				Paphos, Cyprus
			</div>

			<h1>Pool Cleaning in Paphos</h1>

			<p class="body-text">
				Paphos is home to thousands of villas with private pools — many of them holiday rentals that need to be guest-ready every single week. We specialise in keeping those pools spotless, safe, and well-balanced, no matter how heavy the turnover.
			</p>
			<p class="body-text">
				We cover all areas of Paphos including Kato Paphos, Chlorakas, Tala, Peyia, Coral Bay, and the surrounding villages. Our flexible scheduling means we can work around changeover days and short-notice requests.
			</p>

			<h2>Our Paphos Pool Services</h2>
			<ul class="services-list">
				<li><Droplets size={16} />Weekly and bi-weekly cleaning visits</li>
				<li><Droplets size={16} />Full water chemistry testing and balancing</li>
				<li><Droplets size={16} />Vacuuming, skimming, brushing, and tile scrub</li>
				<li><Droplets size={16} />Pump, filter, and equipment checks</li>
				<li><Droplets size={16} />Algae shock treatment when needed</li>
				<li><Droplets size={16} />Holiday rental changeover cleans</li>
			</ul>

			<p class="body-text">
				We understand that in Paphos, a clean pool isn't a luxury — it's part of your rental income. That's why we treat every pool as if the next guests are arriving tomorrow.
			</p>

			<a href="tel:+35700000000" class="cta-button">
				<Phone size={16} />
				Get a Quote in Paphos
			</a>
		</div>

		<footer>
			&copy; {new Date().getFullYear()} Pool Cleaning Cyprus &mdash; Serving Limassol, Paphos, Nicosia, Larnaca & beyond.
		</footer>
	</body>
</html>
